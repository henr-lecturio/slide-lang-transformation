# Video is selected in the Web UI or passed via --video on the CLI.

# Internal phase name for temporary run dataset structure.
PHASE="test"

# Slide ROI in full-frame pixel coordinates (x0,y0,x1,y1).
# Adjust this first if detections are unstable.
ROI_X0=35
ROI_Y0=32
ROI_X1=1415
ROI_Y1=808

# Automatic final image source selection before cleanup / translation / upscale:
# - auto: switch individual final slides from ROI to full image when the slide
#   appears fullscreen (no detected person outside ROI + matching border continuity)
# - off: always keep ROI as the canonical final source
FINAL_SOURCE_MODE_AUTO="auto"

# Fullscreen slide detection heuristics.
FULLSLIDE_SAMPLE_FRAMES=3
FULLSLIDE_BORDER_STRIP_PX=24
FULLSLIDE_MIN_MATCHED_SIDES=2
FULLSLIDE_BORDER_DIFF_THRESHOLD=16
FULLSLIDE_PERSON_BOX_AREA_RATIO=0.02
FULLSLIDE_PERSON_OUTSIDE_RATIO=0.35

# Pipeline step toggles for test runs.
# Scene detection, transcription, and transcript mapping always run.
# The toggles below control only the later postprocess steps.
RUN_STEP_EDIT=1
RUN_STEP_TRANSLATE=1
RUN_STEP_UPSCALE=1
RUN_STEP_TEXT_TRANSLATE=1
RUN_STEP_TTS=1
RUN_STEP_VIDEO_EXPORT=1

# Keyframe offset after transition end (FrameID1) for slide export.
# Increase if blend/fade frames are still visible.
KEYFRAME_SETTLE_FRAMES=10

# Heuristic for short intermediate (-1) segments:
# Exclude this many frames at segment end from stable-frame search
# to avoid selecting right before the next transition ramp.
KEYFRAME_STABLE_END_GUARD_FRAMES=2

# Heuristic for short intermediate (-1) segments:
# Number of future frame-diffs considered when scoring a stable frame.
KEYFRAME_STABLE_LOOKAHEAD_FRAMES=2

# Whisper transcription model used after keyframe extraction.
TRANSCRIPTION_PROVIDER="whisper"
WHISPER_MODEL="medium"
WHISPER_DEVICE="cuda"
WHISPER_COMPUTE_TYPE="float16"
# Optional language code for faster-whisper, e.g. en, de.
WHISPER_LANGUAGE=""

# Google Speech-to-Text v2 alternative.
# Uses sync recognize on local WAV chunks to avoid a required GCS bucket.
GOOGLE_SPEECH_PROJECT_ID=""
GOOGLE_SPEECH_LOCATION="global"
GOOGLE_SPEECH_MODEL="chirp_3"
GOOGLE_SPEECH_LANGUAGE_CODES="en-US"
GOOGLE_SPEECH_CHUNK_SEC=55
GOOGLE_SPEECH_CHUNK_OVERLAP_SEC=0.75

# Speaker-only filter (post transcript mapping):
# Strong stage-1 video overlap threshold for auto-removal.
SPEAKER_FILTER_MIN_STAGE1_VIDEO_RATIO=0.75

# Visual-detail fallback thresholds (low values indicate likely speaker-only frame).
SPEAKER_FILTER_MAX_EDGE_DENSITY=0.011
SPEAKER_FILTER_MAX_LAPLACIAN_VAR=80
SPEAKER_FILTER_MAX_DURATION_SEC=2.5

# Final ROI slide output after speaker-only filtering:
# - none: keep raw final ROI images
# - local: use local lower-right arm cleanup
# - gemini: use Gemini image editing on raw final ROI images
FINAL_SLIDE_POSTPROCESS_MODE="gemini"

# Gemini image editing model. GEMINI_API_KEY must be set in the shell
# environment before starting a run or the local web server.
GEMINI_EDIT_MODEL="gemini-3-pro-image-preview"

# Optional translation pass after final slide cleanup:
# - none: keep the cleaned final ROI slides as-is
# - gemini: translate cleaned final ROI slides with a second Gemini image request
FINAL_SLIDE_TRANSLATION_MODE="gemini"

# Target language used by the Gemini translation step.
FINAL_SLIDE_TARGET_LANGUAGE="French (France)"

# Gemini image model for the translation step.
GEMINI_TRANSLATE_MODEL="gemini-3-pro-image-preview"

# Optional 1:1 translation of the mapped final slide text before TTS.
GEMINI_TEXT_TRANSLATE_MODEL="gemini-2.5-flash"

# Optional TTS voiceover generated from the translated slide text.
GEMINI_TTS_MODEL="gemini-2.5-flash-tts"
GEMINI_TTS_VOICE="Leda"
GOOGLE_TTS_PROJECT_ID="ai-tests-489013"
GOOGLE_TTS_LANGUAGE_CODE="fr-FR"

# Optional upscaling after cleanup / translation:
# - none: keep native slide dimensions
# - swin2sr: run local x4 super-resolution on processed slides
# - replicate_nightmare_realesrgan: use Replicate nightmareai/real-esrgan
FINAL_SLIDE_UPSCALE_MODE="replicate_nightmare_realesrgan"

# Hugging Face Swin2SR model id used for local upscaling.
FINAL_SLIDE_UPSCALE_MODEL="caidas/swin2SR-classical-sr-x4-64"

# Device for the upscaler: auto, cuda, or cpu.
FINAL_SLIDE_UPSCALE_DEVICE="auto"

# Tile parameters for robust local inference on larger slide images.
# 0 disables tiling and processes the whole slide at once.
FINAL_SLIDE_UPSCALE_TILE_SIZE=512
FINAL_SLIDE_UPSCALE_TILE_OVERLAP=16

# Replicate upscaling settings. REPLICATE_API_TOKEN must be set in .env.local
# or the shell environment before starting the web server / runs.
REPLICATE_NIGHTMARE_REALESRGAN_MODEL_REF="nightmareai/real-esrgan"
REPLICATE_NIGHTMARE_REALESRGAN_VERSION_ID="f121d640bd286e1fdc67f9799164c1d5be36ff74576ee11c803ae5b665dd46aa"
REPLICATE_NIGHTMARE_REALESRGAN_PRICE_PER_SECOND=0.000225
REPLICATE_UPSCALE_CONCURRENCY=2

# Slide-video export built from the best available final image set
# (translated_upscaled -> translated -> upscaled -> processed)
# plus the generated voiceover.
VIDEO_EXPORT_MIN_SLIDE_SEC=1
VIDEO_EXPORT_TAIL_PAD_SEC=0.35
VIDEO_EXPORT_WIDTH=1920
VIDEO_EXPORT_HEIGHT=1080
VIDEO_EXPORT_FPS=24
VIDEO_EXPORT_BG_COLOR="white"

VIDEO_PATH="videos/Code of Conduct Basics Lecturio.mp4"
